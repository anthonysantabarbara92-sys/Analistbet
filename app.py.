# --- FUNZIONI CORE ---
def get_poisson_probability(lmbda, x):
    """Calcola la probabilità Poisson per x gol."""
    return poisson.pmf(x, lmbda)

def analyze_with_ai(prompt, key):
    if not key: return "Configura la chiave API per l'analisi IA."
    genai.configure(api_key=key)
    model = genai.GenerativeModel('gemini-1.5-flash')
    response = model.generate_content(prompt)
    return response.text

# --- LAYOUT PRINCIPALE ---
st.title("⚽ Match Analyst Pro: IA & Statistica")

tab1, tab2 = st.tabs(["📊 Analisi Match", "⚙️ Gestione Dati"])

with tab1:
    col_a, col_b = st.columns(2)
    
    with col_a:
        st.subheader("🏠 Squadra Casa")
        h_name = st.text_input("Nome Squadra Casa", "Inter")
